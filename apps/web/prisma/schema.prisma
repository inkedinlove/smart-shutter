generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id                   String                @id @default(cuid())
  deviceId             String                @unique
  label                String
  board                String                @default("esp32")
  status               String                @default("unprovisioned")
  firmwareVersion      String?
  mqttCommandTopic     String
  mqttStatusTopic      String
  brokerProfile        String                @default("hivemq-dev")
  otaAutoUpdateEnabled Boolean               @default(false)
  otaAutoUpdateChannel String                @default("stable")
  credentialMode       String                @default("shared")
  credentialStatus     String                @default("active")
  credentialIssuedAt   DateTime?
  credentialRevokedAt  DateTime?
  mqttClientId         String?
  mqttUsernameRef      String?
  certificateFingerprint String?
  ownerProfileId       String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ownerProfile         UserProfile?          @relation(fields: [ownerProfileId], references: [id], onDelete: SetNull)
  claims               DeviceClaim[]
  commandAudits        DeviceCommandAudit[]
  updateEvents         DeviceUpdateEvent[]
  provisioningSessions ProvisioningSession[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  emailVerificationRequired Boolean @default(false)
  image         String?
  passwordHash  String?
  role          String    @default("customer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  provisioningSessions ProvisioningSession[] @relation("ProvisioningSessionCreatedByUser")
}

model UserProfile {
  id          String       @id @default(cuid())
  userId      String?      @unique
  displayName String
  email       String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  devices     Device[]
  claims      DeviceClaim[]
  commandAudits DeviceCommandAudit[]
  voiceIntegrations VoiceIntegrationAccount[]
  provisioningSessions ProvisioningSession[] @relation("ProvisioningSessionCreatedByProfile")
}

model DeviceClaim {
  id         String      @id @default(cuid())
  deviceId   String
  profileId  String?
  claimCode  String      @unique
  shortDisplayCode String?
  deviceSetupUrl   String?
  status     String      @default("created")
  expiresAt  DateTime
  claimedAt  DateTime?
  createdAt  DateTime    @default(now())
  device     Device      @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  profile    UserProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([profileId])
  @@index([expiresAt])
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model FirmwareRelease {
  id         String   @id @default(cuid())
  version    String   @unique
  channel    String   @default("stable")
  board      String   @default("esp32")
  artifactUrl String
  sha256     String
  sizeBytes  Int?
  notes      String?
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model DeviceUpdateEvent {
  id                  String   @id @default(cuid())
  deviceId            String
  firmwareVersionFrom String?
  firmwareVersionTo   String
  status              String
  detail              String?
  createdAt           DateTime @default(now())
  device              Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@index([deviceId, createdAt])
}

model DeviceCommandAudit {
  id             String       @id @default(cuid())
  deviceId       String
  actorProfileId String?
  commandType    String
  result         String
  detail         String?
  createdAt      DateTime     @default(now())
  device         Device       @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  actorProfile   UserProfile? @relation(fields: [actorProfileId], references: [id], onDelete: SetNull)

  @@index([deviceId, createdAt])
  @@index([actorProfileId, createdAt])
  @@index([result, createdAt])
}

model ProvisioningSession {
  id          String    @id @default(cuid())
  deviceId    String?
  pairingCode String    @unique
  status      String    @default("created")
  artifactType String   @default("package")
  board       String    @default("unknown")
  fileName    String?
  wifiMode    String    @default("factory")
  wifiSsidHint String?
  createdByUserId String?
  createdByProfileId String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  device      Device?   @relation(fields: [deviceId], references: [deviceId], onDelete: SetNull)
  createdByUser User? @relation("ProvisioningSessionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByProfile UserProfile? @relation("ProvisioningSessionCreatedByProfile", fields: [createdByProfileId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([createdByUserId, createdAt])
  @@index([createdByProfileId, createdAt])
  @@index([expiresAt])
  @@index([status, createdAt])
}

model VoiceIntegrationAccount {
  id        String      @id @default(cuid())
  profileId String
  provider  String
  status    String      @default("not_connected")
  linkedAt  DateTime?
  revokedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, provider])
  @@index([provider, status])
}
